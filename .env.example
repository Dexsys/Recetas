# ==============================
# Flask App
# ==============================
SECRET_KEY=cambia_esto_por_una_clave_segura
# development | production
APP_ENV=development
UPLOAD_FOLDER=uploads

# ==============================
# Base de Datos - MariaDB
#
# Desarrollo : DB_NAME=dev_sabor_familia
# Produccion : DB_NAME=sabor_familia  (usa .env.prod)
# ==============================
DB_HOST=192.168.x.x
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=dev_sabor_familia

# ==============================
# Flask CLI / Migrations
# ==============================
FLASK_APP=app:create_app

# ==============================
# Deploy (solo maquina de desarrollo)
# ==============================
DEPLOY_SSH_PASSWORD=password_del_servidor_produccion
DEPLOY_SERVICE_NAME=recetas
DEPLOY_PYTHON=python3
DEPLOY_REMOTE_VENV=.venv

# ==============================
# SMTP (Recuperacion de password)
# ==============================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
MAIL_DEFAULT_SENDER=tu_email@gmail.com
