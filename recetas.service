[Unit]
Description=Servicio para la aplicación de gestion Recetas y sabores familiares
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/Developer/Flask/Recetas
Environment="PATH=/home/ubuntu/Developer/Flask/Recetas/.venv/bin"
ExecStart=/home/ubuntu/Developer/Flask/Recetas/.venv/bin/waitress-serve --host 127.0.0.1 --port 5110 wsgi:app
StandardError=/home/ubuntu/Developer/Flask/Recetas/logs/error.log
StandardOutput=/home/ubuntu/Developer/Flask/Recetas/logs/access.log
ExecReload=/bin/kill -s HUP $MAINPID
KillMode=mixed
TimeoutStopSec=5
PrivateTmp=true
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
